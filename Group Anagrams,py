class Solution:
    def groupAnagrams(self, strs: List[str]) -> List[List[str]]:

        newdict=dict()
        for i in range(len(strs)):
            key= "".join(sorted(strs[i]))
            if key not in newdict:
                newdict[key]=[]
            newdict[key].append(strs[i])
        return list(newdict.values())
